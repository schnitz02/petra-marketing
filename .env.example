# ─── Required ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Database ───────────────────────────────────────────────────────
# SQLite (dev) — leave blank for default ./marketing.db
# PostgreSQL (prod) — postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# ─── Optional: Social Scraping ──────────────────────────────────────
INSTAGRAM_SESSION_ID=
POC_MODE=true

# ─── Optional: GA4 ─────────────────────────────────────────────────
GA4_PROPERTY_ID=
GA4_CREDENTIALS_JSON=

# ─── Optional: Deployment ──────────────────────────────────────────
ALLOWED_ORIGINS=
AGENT_API_KEY=
